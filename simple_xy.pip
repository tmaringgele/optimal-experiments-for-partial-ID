MAXIMIZE
  obj: objvar

SUBJECT TO
a0: X0 * Y00 + X0 * Y01 + -0.6 X0 = 0
a1: X0 * Y10 + X0 * Y11 + -0.4 X0 = 0
a2: X1 * Y00 + X1 * Y10 + -0.2 X1 = 0
a3: X1 * Y01 + X1 * Y11 + -0.8 X1 = 0
a4: Y00 + Y01 + Y10 + Y11 + -1.0 = 0
a5: X0 + X1 + -1.0 = 0
a6: Y01 + -1 Y10 + -1 objvar = 0

BOUNDS
  0 <= X0 <= 1
  0 <= X1 <= 1
  0 <= Y00 <= 1
  0 <= Y01 <= 1
  0 <= Y10 <= 1
  0 <= Y11 <= 1
  -1 <= objvar <= 1

END